<Window x:Class="PixelLab_Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PixelLab_Desktop.ViewModels"
        xmlns:views="clr-namespace:PixelLab_Desktop.Views"
        Title="PixelLab - Image Laboratory" Height="650" Width="1577"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Root: main content + collapsible sidebar -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Main workspace -->
            <ColumnDefinition Width="*"/>
            <!-- Sidebar (collapsed by default, Width set in code) -->
            <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             Left: main workspace
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Load Image"   Command="{Binding LoadImageCommand}"    Padding="10,5" Margin="0,0,6,0"/>
                <Button Content="Save Image"   Command="{Binding SaveImageCommand}"    Padding="10,5" Margin="0,0,6,0"/>
                <Separator Width="1" Background="Gray" Margin="4,0"/>
                <Button Content="CMYK"         Command="{Binding ConvertToCmykCommand}"  Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="HSV"          Command="{Binding ConvertToHsvCommand}"   Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="YUV"          Command="{Binding ConvertToYuvCommand}"   Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="YCbCr"        Command="{Binding ConvertToYCbCrCommand}" Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="LAB"          Command="{Binding ConvertToLabCommand}"   Padding="8,5" Margin="0,0,4,0"/>
                <Button Content="Reset"        Command="{Binding ResetToOriginalCommand}" Padding="8,5" Margin="0,0,4,0"/>
                <Separator Width="1" Background="Gray" Margin="4,0"/>
                <Button Content="Color Controls" Click="OpenColorControlsWindow_Click" Padding="8,5" Margin="0,0,6,0"/>
                <Separator Width="1" Background="Gray" Margin="4,0"/>
                <!-- Posterize -->
                <TextBlock Text="Colors:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Slider x:Name="PosterizeSlider" Minimum="2" Maximum="256"
                        Value="{Binding ColorLevels, Mode=TwoWay}"
                        Width="90" VerticalAlignment="Center"
                        TickFrequency="1" IsSnapToTickEnabled="True"/>
                <TextBlock Text="{Binding ColorLevels}" VerticalAlignment="Center"
                           Margin="4,0,4,0" MinWidth="28"/>
                <Button Content="Posterize" Command="{Binding ApplyPosterizeCommand}" Padding="8,5" Margin="0,0,6,0"/>
                <Separator Width="1" Background="Gray" Margin="4,0"/>
                <!-- Sidebar toggle -->
                <Button x:Name="BtnToggleSidebar" Content="▶ Color Spaces"
                        Click="ToggleSidebar_Click"
                        Padding="8,5" Background="#2D5FA6" Foreground="White"
                        FontWeight="SemiBold"/>
            </WrapPanel>

            <!-- Image display -->
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="#F0F0F0">
                <Image Source="{Binding CurrentImage}" Stretch="Uniform" Margin="5"/>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="2" Text="{Binding ImageInfo}"
                       HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Bold"/>
        </Grid>

        <!-- ══════════════════════════════════════════
             Right: collapsible sidebar
        ══════════════════════════════════════════ -->
        <views:ColorSpaceSidebar x:Name="Sidebar"
                                 Grid.Column="1"
                                 Visibility="Collapsed"/>
    </Grid>
</Window>
