<Window x:Class="PixelLab_Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PixelLab_Desktop.ViewModels"
        Title="PixelLab - Image Laboratory" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Load Image" Command="{Binding LoadImageCommand}" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="Save Image" Command="{Binding SaveImageCommand}" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="CMYK" Command="{Binding ConvertToCmykCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="HSV" Command="{Binding ConvertToHsvCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="YUV" Command="{Binding ConvertToYuvCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="YCbCr" Command="{Binding ConvertToYCbCrCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="LAB" Command="{Binding ConvertToLabCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="Reset" Command="{Binding ResetToOriginalCommand}" Padding="8,5" Margin="0,0,5,0"/>
            <Button Content="Color Controls" Click="OpenColorControlsWindow_Click" Padding="8,5" Margin="20,0,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="#F0F0F0">
            <Image Source="{Binding CurrentImage}" Stretch="Uniform" Margin="5"/>
        </Border>
        <TextBlock Grid.Row="2" Text="{Binding ImageInfo}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Bold"/>
    </Grid>
</Window>