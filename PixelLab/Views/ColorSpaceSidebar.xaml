<UserControl x:Class="PixelLab_Desktop.Views.ColorSpaceSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Width="320">

    <UserControl.Resources>
        <Style x:Key="SpaceBtn" TargetType="Button">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="44"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- space buttons -->
            <RowDefinition Height="*"/>     <!-- 3D view -->
            <RowDefinition Height="4"/>     <!-- divider -->
            <RowDefinition Height="Auto"/>  <!-- color info -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Color space buttons ── -->
        <WrapPanel Grid.Row="0" Margin="6,8,6,4" HorizontalAlignment="Center">
            <Button Content="RGB"   Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="RGB"/>
            <Button Content="HSV"   Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="HSV"/>
            <Button Content="CMYK"  Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="CMYK"/>
            <Button Content="YUV"   Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="YUV"/>
            <Button Content="YCbCr" Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="YCbCr"/>
            <Button Content="LAB"   Style="{StaticResource SpaceBtn}" Click="SpaceBtn_Click" Tag="LAB"/>
        </WrapPanel>

        <!-- ── Row 1: 3D WebView (all spaces) ── -->
        <wv2:WebView2 x:Name="WebView3D" Grid.Row="1" Margin="6,4"/>

        <!-- ── Row 2: Divider ── -->
        <Rectangle Grid.Row="2" Fill="#444"/>

        <!-- ── Row 3: Color info panel ── -->
        <StackPanel Grid.Row="3" Margin="10,8,10,10">

            <!-- Swatch + title -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="Picked Color" Foreground="#AAA" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <Border x:Name="ColorSwatch" Width="36" Height="24" CornerRadius="4"
                        Background="White" BorderBrush="#555" BorderThickness="1"
                        DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- 6-system value grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="22"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="RGB"   Foreground="#FF6B6B" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="HSV"   Foreground="#FFD93D" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="CMYK"  Foreground="#6BCB77" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="YUV"   Foreground="#4D96FF" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="YCbCr" Foreground="#C77DFF" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="LAB"   Foreground="#FF9F1C" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>

                <TextBlock x:Name="TxtRgb"   Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtHsv"   Grid.Row="1" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtCmyk"  Grid.Row="2" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtYuv"   Grid.Row="3" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtYCbCr" Grid.Row="4" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtLab"   Grid.Row="5" Grid.Column="1" Foreground="White" FontSize="11" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
